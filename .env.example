DATABASE_URL="file:./dev.db"

# Optional text-generation configuration.
# Ollama is the default local text-generation provider.
# Set AI_PROVIDER="openai" and provide OPENAI_API_KEY to use hosted OpenAI instead.
AI_PROVIDER="ollama"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.3"
OLLAMA_BASE_URL="http://localhost:11434/v1"
OLLAMA_MODEL="llama3.1"
LLM_JSON_TIMEOUT_MS="60000"

# Set to 1/true/yes/on to force deterministic mock AI outputs
# through the same generation workflow without calling OpenAI.
OPENAI_MOCK_MODE="0"

# Optional standalone ML recommendation scoring.
# HYBRID_RULES_ML is the default out-of-the-box mode and appears as "ML-Assisted Rules" in the UI.
# RULES_ONLY uses deterministic rules only.
# ML_SHADOW runs ML metadata without changing recommendations.
# HYBRID_RULES_ML blends ML scores into recommendations while guardrails remain final.
ML_RECOMMENDATION_MODE="HYBRID_RULES_ML"

# Optional guarded LLM decisioning configuration.
# This is separate from ML recommendation mode.
# RULES_ONLY disables LLM decision critique/ranking.
# LLM_CRITIC_SHADOW critiques decisions without changing final output.
# LLM_RANKING_SHADOW ranks allowed candidates in shadow mode.
# LLM_ASSISTED_GUARDED can influence selected candidates only when deterministic validators pass.
# HUMAN_APPROVAL_REQUIRED routes exception posture to human review.
GUARDED_DECISIONING_MODE="LLM_CRITIC_SHADOW"

# Demo role gate for restricted guarded modes.
# LLM_ASSISTED_GUARDED can be enabled by AI_GOVERNANCE_ADMIN or REVENUE_OPERATIONS_ADMIN.
# HUMAN_APPROVAL_REQUIRED can be enabled by AI_GOVERNANCE_ADMIN or DEAL_DESK_ADMIN.
DEMO_USER_ROLE="AI_GOVERNANCE_ADMIN"

ML_PYTHON_BIN=".venv-ml/bin/python"
# Optional override. Leave empty to use the active model from ml/model-registry.json.
ML_MODEL_PATH=""
ML_PREDICTION_SCRIPT_PATH="ml/predict.py"
# Optional. When set, the app calls a persistent local ML service instead of spawning Python.
ML_SERVICE_URL=""
