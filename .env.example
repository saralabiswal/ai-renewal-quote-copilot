DATABASE_URL="file:./dev.db"

# Optional OpenAI configuration
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.3"

# Set to 1/true/yes/on to force deterministic mock AI outputs
# through the same generation workflow without calling OpenAI.
OPENAI_MOCK_MODE="0"

# Optional standalone ML recommendation scoring.
# HYBRID_RULES_ML is the default out-of-the-box mode and appears as "ML-Assisted Rules" in the UI.
# RULES_ONLY uses deterministic rules only.
# ML_SHADOW runs ML metadata without changing recommendations.
# HYBRID_RULES_ML blends ML scores into recommendations while guardrails remain final.
ML_RECOMMENDATION_MODE="HYBRID_RULES_ML"
ML_PYTHON_BIN=".venv-ml/bin/python"
# Optional override. Leave empty to use the active model from ml/model-registry.json.
ML_MODEL_PATH=""
ML_PREDICTION_SCRIPT_PATH="ml/predict.py"
# Optional. When set, the app calls a persistent local ML service instead of spawning Python.
ML_SERVICE_URL=""
