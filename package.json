{
  "name": "subscription-renewal-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered renewal decision support demo for enterprise SaaS teams.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "db:reset:clean": "./scripts/clean-reseed.sh",
    "app:reset:run": "./scripts/reset-and-run.sh",
    "app:smoke": "./scripts/smoke-test.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "next": "^15.0.3",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.14.0",
    "eslint-config-next": "^15.0.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
